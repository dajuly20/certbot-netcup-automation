# Sensitive files - DO NOT COMMIT
*.ini
*credentials.ini
*.key
*.pem

# But allow scripts with 'credentials' in the name
!scripts/*credentials*.sh

# Log files
*.log
logs/

# Backup files
*.bak
*.backup
*~

# Lock files
*.lock

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/
